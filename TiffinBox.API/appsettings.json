{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "your-super-secret-key-with-minimum-32-characters-long",
    "Issuer": "https://api.tiffinbox.com",
    "Audience": "tiffinbox-clients",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Razorpay": {
    "KeyId": "rzp_test_your_key_id_here",
    "KeySecret": "your_secret_key_here",
    "WebhookSecret": "your_webhook_secret_here"
  },
  "SmsSettings": {
    "AccountSid": "your_twilio_account_sid",
    "AuthToken": "your_twilio_auth_token",
    "FromPhoneNumber": "+1234567890",
    "Provider": "Twilio"
  },
  "EmailSettings": {
    "ApiKey": "your_sendgrid_api_key",
    "FromEmail": "noreply@tiffinbox.com",
    "FromName": "TiffinBox Pro",
    "Provider": "SMTP",
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "SmtpUsername": "your-email@gmail.com",
    "SmtpPassword": "your-app-password",
    "EnableSsl": true
  }
}
